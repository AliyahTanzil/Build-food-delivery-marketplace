{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "baseUrl": ".",
    "typeRoots": ["./node_modules/@types"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/main.tsx", "src/App.tsx", "src/vite-env.d.ts", "src/vite/**/*.{ts,tsx}", "src/lib/types.ts", "src/lib/utils.ts", "src/lib/constants.ts"],
  "exclude": ["node_modules", "src/app", "src/components", "src/lib/supabase", "src/lib/auth.ts", "src/lib/stripe.ts"]
}
